{
  "version": 1,
  "display": {
    "width": 480,
    "height": 480,
    "background": "#000000"
  },

  "elements": [
    {
      "id": "rpm-path",
      "type": "path",
      "animation": {
        "type": "trim",
        "mode": "sweep",
        "start_angle": 130,
        "end_angle": 340,
        "min_value": 0,
        "max_value": 8000,
        "binding": {
          "source": "pid",
          "pid": "engine_rpm"
        }
      }
    },

    {
      "id": "temp-path",
      "type": "path",
      "animation": {
        "type": "trim",
        "mode": "sweep",
        "start_angle": 230,
        "end_angle": 310,
        "min_value": 160,
        "max_value": 260,
        "binding": {
          "source": "pid",
          "pid": "coolant_temp"
        }
      }
    }
  ]
}